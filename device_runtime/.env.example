# Copy to .env in this same folder on the Raspberry Pi.
# Optional compatibility fallback: /etc/device-runtime/device-runtime.env
DEVICE_ID=raspi-01
DEVICE_WS_URL=ws://192.168.1.10:8000/ws
DEVICE_AUTH_TOKEN=
DEVICE_TRANSPORT_ADAPTER=websocket
DEVICE_HARDWARE_PROFILE=whisplay
DEVICE_DISPLAY_ADAPTER=whisplay
# Safe Raspberry default for the integrated Whisplay bundle.
# The runtime uses the vendor-owned Whisplay button instead of GPIO17.
DEVICE_BUTTON_ADAPTER=whisplay
# Keep audio null by default unless you have confirmed an external path that does not
# conflict with the integrated Whisplay microphone/speaker stack.
DEVICE_AUDIO_IN_ADAPTER=null
DEVICE_AUDIO_OUT_ADAPTER=null
DEVICE_POWER_ADAPTER=pisugar
DEVICE_RGB_ADAPTER=hardware
DEVICE_WHISPLAY_DRIVER_PATH=~/Whisplay/Driver
DEVICE_WHISPLAY_BACKLIGHT=50
DEVICE_PISUGAR_MODE=auto
DEVICE_PISUGAR_HOST=127.0.0.1
DEVICE_PISUGAR_PORT=8423
DEVICE_PISUGAR_COMMAND=
DEVICE_RGB_PROFILE=default
DEVICE_RECONNECT_INITIAL_MS=1000
DEVICE_RECONNECT_MAX_MS=6000
DEVICE_BUTTON_LONG_PRESS_MS=900
DEVICE_BUTTON_DOUBLE_PRESS_MS=350
DEVICE_AUDIO_SAMPLE_RATE=16000
DEVICE_AUDIO_CHANNELS=1
DEVICE_AUDIO_CHUNK_MS=120
DEVICE_DIAGNOSTICS_ENABLED=true
DEVICE_FAIL_FAST_ON_MISSING_TRANSPORT=true
DEVICE_FAIL_FAST_ON_MISSING_BUTTON=false

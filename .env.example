# Backend mode: mock | http (or real) | ws
OPENCLAWD_MODE=mock

# Required when OPENCLAWD_MODE=http or OPENCLAWD_MODE=real
OPENCLAWD_BASE_URL=
OPENCLAWD_CHAT_ENDPOINT=/api/chat
OPENCLAWD_API_KEY=
OPENCLAWD_TIMEOUT_S=25

# Required when OPENCLAWD_MODE=ws
OPENCLAWD_WS_URL=
OPENCLAWD_WS_BEARER_TOKEN=
OPENCLAWD_WS_HEADERS={}
OPENCLAWD_WS_EXTRA_PAYLOAD={}
OPENCLAWD_WS_REQUEST_TYPE=
OPENCLAWD_WS_AGENT_FIELD=agent_id
OPENCLAWD_WS_INPUT_FIELD=input
OPENCLAWD_WS_SESSION_FIELD=session_id
OPENCLAWD_WS_PARTIAL_TYPES=assistant.text.partial,partial,delta,response.chunk
OPENCLAWD_WS_FINAL_TYPES=assistant.text.final,final,done,response.final
OPENCLAWD_WS_TIMEOUT_S=25
OPENCLAWD_WS_RECEIVE_TIMEOUT_S=4
OPENCLAWD_WS_MAX_MESSAGES=64

# Streaming tune
ASSISTANT_STREAM_CHUNK_SIZE=24
ASSISTANT_STREAM_CHUNK_DELAY=0.12

# Optional: send assistant.audio.start/chunk/end with fake payloads
ENABLE_FAKE_AUDIO=false
LOOPBACK_AUDIO_ENABLED=true
LOOPBACK_CHUNK_MS=120
AUDIO_REPLY_MODE=assistant

# Local speech pipeline (Whisper STT + local TTS)
ENABLE_WHISPER_STT=true
WHISPER_MODEL_SIZE=base
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=int8
WHISPER_BEAM_SIZE=1
WHISPER_LANGUAGE=es
WHISPER_VAD_FILTER=true
ENABLE_LOCAL_TTS=true
TTS_BACKEND=auto
TTS_RATE=175
TTS_VOLUME=1.0
TTS_VOICE=

# Basic device auth and access control (backend)
SIM_DEVICE_AUTH_TOKEN=
SIM_ALLOWED_DEVICE_IDS=
SIM_AVAILABLE_AGENTS=assistant-general,assistant-tech,assistant-ops

# Client defaults (simulators)
SIM_WS_URL=ws://127.0.0.1:8000/ws
SIM_DEVICE_ID=sim-device-001
